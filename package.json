{
  "name": "netbrowse-voice",
  "version": "0.30.1",
  "private": true,
  "description": "Netbrowse Voice modular PBX and intelligent communications platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm run dev --workspace @netbrowse-voice/api",
    "dev:web": "npm run dev --workspace @netbrowse-voice/web"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9"
  }
}
