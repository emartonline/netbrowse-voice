#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  printf 'Netbrowse Voice Asterisk status: root privileges are required\n' >&2
  exit 1
fi
if (( $# != 0 )); then
  printf 'Netbrowse Voice Asterisk status: arguments are not accepted\n' >&2
  exit 1
fi

/usr/sbin/asterisk -rx "pjsip show contacts"
printf '\n--- Netbrowse Voice outbound registrations ---\n'
/usr/sbin/asterisk -rx "pjsip show registrations" || true
